    "strict": true,
    "credentials": [
      "dist/credentials/SeedanceApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Seedance/Seedance.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.23.1",
    "@types/node": "^22.15.3",
    "eslint": "9.29.0",
    "n8n-workflow": "^2.13.1",
    "typescript": "^5.8.3"
  }
}
