{
  "name": "n8n-nodes-seedance2",
  "version": "0.1.0",
  "description": "n8n community node for Seedance video task lifecycle integration.",
  "license": "MIT",
  "homepage": "https://github.com/your-org/n8n-nodes-seedance2",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "seedance",
    "video-generation"
  ],
  "author": {
    "name": "GSD Executor"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/n8n-nodes-seedance2.git"
  },
  "engines": {
    "node": "22.x"
  },
  "main": "index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "n8n-node build",
    "dev": "node scripts/dev.mjs",
    "lint": "n8n-node lint",
